# ── MindBridge Environment Variables ──────────────────
# Copy this file to .env and fill in the values

# Django
DJANGO_SECRET_KEY=your-secret-key-here-change-this
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave blank to use SQLite)
# DB_NAME=mindbridge_db
# DB_USER=postgres
# DB_PASSWORD=yourpassword
# DB_HOST=localhost
# DB_PORT=5432

# Redis (leave blank to use in-memory channel layer)
# REDIS_URL=redis://localhost:6379
